{
	"$schema": "https://turbo.build/schema.json",
	"concurrency": "20",
	"globalEnv": ["CI"],
	"tasks": {
		"clean": {
			"cache": false
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": ["coverage/**", "*.xml"]
		},
		"db:generate": {
			"cache": false,
			"dependsOn": ["@prismalens/config#build"]
		},
		"@prismalens/database#build": {
			"dependsOn": ["^build", "db:generate"],
			"outputs": ["dist/**", "prisma/generated/**"]
		},
		"@prismalens/database#typecheck": {
			"dependsOn": ["^build", "db:generate"]
		},
		"db:migrate": {
			"cache": false,
			"persistent": true
		},
		"db:deploy": {
			"cache": false
		},
		"db:init": {
			"cache": false
		},
		"db:studio": {
			"cache": false,
			"persistent": true
		},
		"db:reset": {
			"cache": false
		},
		"//#format-and-lint": {},
		"//#format-and-lint:fix": {
			"cache": false
		}
	}
}
