{
	"name": "@prismalens/api",
	"version": "0.0.1",
	"description": "PrismaLens API - NestJS REST API server",
	"author": "PrismaLens Team",
	"private": true,
	"license": "Apache-2.0",
	"type": "module",
	"scripts": {
		"dev": "nest start --watch --preserveWatchOutput",
		"build": "nest build",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:cov": "vitest run --coverage",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist && rm -rf node_modules",
		"openapi:generate": "tsx scripts/generate-openapi.ts"
	},
	"dependencies": {
		"@nestjs/bullmq": "^11.0.4",
		"@nestjs/common": "catalog:",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "catalog:",
		"@nestjs/event-emitter": "^3.1.0",
		"@nestjs/platform-express": "^11.1.28",
		"@nestjs/swagger": "^11.4.6",
		"@orpc/nest": "^1.14.8",
		"@orpc/openapi": "^1.14.8",
		"@orpc/server": "^1.14.8",
		"@orpc/zod": "^1.14.8",
		"@prismalens/auth": "workspace:*",
		"@prismalens/config": "workspace:*",
		"@prismalens/contracts": "workspace:*",
		"@prismalens/database": "workspace:*",
		"@prismalens/integrations": "workspace:*",
		"@prismalens/logger": "workspace:*",
		"better-auth": "catalog:",
		"bullmq": "catalog:",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"ioredis": "catalog:",
		"reflect-metadata": "^0.2.2",
		"rxjs": "catalog:"
	},
	"devDependencies": {
		"@faker-js/faker": "^10.5.0",
		"@nestjs/cli": "^11.0.23",
		"@nestjs/schematics": "^11.1.0",
		"@nestjs/testing": "^11.1.27",
		"@nestjs/throttler": "^6.5.0",
		"@swc/core": "^1.15.43",
		"@types/express": "^5.0.6",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "^4.1.9",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"unplugin-swc": "^1.5.9",
		"vitest": "catalog:"
	},
	"engines": {
		"node": ">=24.0.0"
	}
}
