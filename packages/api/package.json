{
	"name": "@prismalens/api",
	"version": "0.1.0",
	"description": "PrismaLens API - NestJS REST API server",
	"author": "PrismaLens Team",
	"private": true,
	"license": "ELv2",
	"type": "module",
	"scripts": {
		"dev": "nest start --watch --preserveWatchOutput",
		"build": "nest build",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "NODE_OPTIONS=--experimental-vm-modules jest",
		"test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
		"test:cov": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist && rm -rf node_modules",
		"openapi:generate": "tsx scripts/generate-openapi.ts"
	},
	"dependencies": {
		"@nestjs/bullmq": "^11.0.4",
		"@nestjs/common": "^11.1.27",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.1.27",
		"@nestjs/event-emitter": "^3.1.0",
		"@nestjs/platform-express": "^11.1.27",
		"@nestjs/swagger": "^11.4.5",
		"@orpc/nest": "^1.14.6",
		"@orpc/openapi": "^1.14.6",
		"@orpc/server": "^1.14.6",
		"@orpc/zod": "^1.14.6",
		"@prismalens/auth": "workspace:*",
		"@prismalens/config": "workspace:*",
		"@prismalens/contracts": "workspace:*",
		"@prismalens/database": "workspace:*",
		"@prismalens/integrations": "workspace:*",
		"@prismalens/logger": "workspace:*",
		"better-auth": "~1.6.23",
		"bullmq": "^5.79.2",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"ioredis": "^5.11.1",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@faker-js/faker": "^10.5.0",
		"@nestjs/cli": "^11.0.23",
		"@nestjs/schematics": "^11.1.0",
		"@nestjs/testing": "^11.1.27",
		"@nestjs/throttler": "^6.5.0",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/node": "^24.13.2",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"globals": "^17.7.0",
		"jest": "^30.4.2",
		"prettier": "^3.9.4",
		"ts-jest": "^29.4.11",
		"tsx": "^4.22.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.62.1"
	},
	"engines": {
		"node": ">=24.0.0"
	}
}
