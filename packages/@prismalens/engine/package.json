{
	"name": "@prismalens/engine",
	"version": "0.2.0",
	"description": "Two-tier AI investigation engine for PrismaLens — a supervisor that rents a coding-agent harness and reduces its evidence into an ordered-hypothesis report",
	"license": "Apache-2.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"NOTICE"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prismalens/prismalens.git",
		"directory": "packages/@prismalens/engine"
	},
	"homepage": "https://prismalens.io",
	"bugs": "https://github.com/prismalens/prismalens/issues",
	"keywords": [
		"sre",
		"incident-response",
		"root-cause-analysis",
		"investigation",
		"ai",
		"agent"
	],
	"engines": {
		"node": ">=22"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"eval": "tsx eval/run-evals.ts",
		"eval:typecheck": "tsc --noEmit -p eval/tsconfig.json",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.3.199",
		"@prismalens/config": "workspace:*",
		"@prismalens/contracts": "workspace:*",
		"ai": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
