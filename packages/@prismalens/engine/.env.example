# Dev CLI config. Copy to `.env` (gitignored) and fill in. NEVER commit a real key.
# The engine is a LIBRARY; consumers (api/worker) supply config via @prismalens/config.
# These vars only drive the dev CLI.

# Default provider is `google` (native Gemini). Free key: https://aistudio.google.com
GOOGLE_API_KEY=
PRISMALENS_LLM_MODEL=gemini-2.5-flash

# Other providers (--provider openai|groq|ollama|custom) read their own key env var and
# go through the universal OpenAI-compatible backend. Local Ollama needs no key:
#   --provider ollama --model qwen2.5      (uses OLLAMA_HOST or http://localhost:11434)
# OPENAI_API_KEY=
# GROQ_API_KEY=
# OLLAMA_HOST=http://localhost:11434
# OPENAI_BASE_URL=          # for --provider custom

# Read-only shell allowlist for the CLI (defaults to allowlist.example.json).
PRISMALENS_ALLOWLIST_FILE=allowlist.example.json
