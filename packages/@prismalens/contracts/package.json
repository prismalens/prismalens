{
	"name": "@prismalens/contracts",
	"version": "0.1.0",
	"description": "Shared API contracts and Zod schemas for PrismaLens",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./schemas": {
			"types": "./dist/schemas/index.d.ts",
			"import": "./dist/schemas/index.js"
		},
		"./contracts": {
			"types": "./dist/contracts/index.d.ts",
			"import": "./dist/contracts/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"clean": "rm -rf dist && rm -rf node_modules",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@orpc/contract": "catalog:",
		"@prismalens/config": "workspace:*",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"typescript": "catalog:"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"sideEffects": false,
	"files": [
		"dist",
		"src"
	]
}
