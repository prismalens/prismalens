{
	"name": "@prismalens/contracts",
	"version": "0.1.1",
	"private": true,
	"license": "Apache-2.0",
	"description": "Shared API contracts and Zod schemas for PrismaLens",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./schemas": {
			"types": "./dist/schemas/index.d.ts",
			"import": "./dist/schemas/index.js"
		},
		"./contracts": {
			"types": "./dist/contracts/index.d.ts",
			"import": "./dist/contracts/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"clean": "rm -rf dist && rm -rf node_modules",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@orpc/contract": "catalog:",
		"@prismalens/config": "workspace:*",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prismalens/prismalens.git",
		"directory": "packages/@prismalens/contracts"
	},
	"homepage": "https://prismalens.io",
	"bugs": "https://github.com/prismalens/prismalens/issues",
	"keywords": [
		"prismalens",
		"contracts",
		"zod",
		"schemas"
	],
	"engines": {
		"node": ">=22"
	},
	"sideEffects": false,
	"files": [
		"dist",
		"src",
		"NOTICE"
	],
	"publishConfig": {
		"access": "public"
	}
}
