{
	"name": "@prismalens/logger",
	"version": "0.1.0",
	"license": "Apache-2.0",
	"private": true,
	"description": "Wide events logging with tail sampling for PrismaLens",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./nestjs": {
			"types": "./dist/integrations/nestjs/index.d.ts",
			"import": "./dist/integrations/nestjs/index.js"
		},
		"./standalone": {
			"types": "./dist/integrations/standalone/index.d.ts",
			"import": "./dist/integrations/standalone/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"clean": "rm -rf dist && rm -rf node_modules",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@prismalens/config": "workspace:*",
		"pino": "^9.14.0"
	},
	"peerDependencies": {
		"@nestjs/common": ">=10.0.0",
		"@nestjs/core": ">=10.0.0"
	},
	"peerDependenciesMeta": {
		"@nestjs/common": {
			"optional": true
		},
		"@nestjs/core": {
			"optional": true
		}
	},
	"devDependencies": {
		"@nestjs/common": "catalog:",
		"@nestjs/core": "catalog:",
		"@types/node": "catalog:",
		"rxjs": "catalog:",
		"typescript": "catalog:"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"files": [
		"dist",
		"src"
	],
	"publishConfig": {
		"access": "public"
	}
}
