{
	"name": "@prismalens/database",
	"version": "0.1.0",
	"description": "Shared database adapter and Prisma client for PrismaLens",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"clean": "rm -rf dist && rm -rf node_modules",
		"db:init": "tsx scripts/db-init.ts",
		"db:generate": "prisma generate --config prisma.config.ts",
		"db:migrate": "prisma migrate dev --config prisma.config.ts",
		"db:deploy": "prisma migrate deploy --config prisma.config.ts",
		"db:studio": "prisma studio --config prisma.config.ts",
		"db:reset": "prisma migrate reset --config prisma.config.ts",
		"db:seed": "prisma db seed --config prisma.config.ts"
	},
	"dependencies": {
		"@prisma/adapter-better-sqlite3": "^7.8.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@prismalens/config": "workspace:*",
		"dotenv": "catalog:",
		"pg": "^8.22.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "catalog:",
		"@types/pg": "^8.20.0",
		"prisma": "^7.8.0",
		"typescript": "catalog:"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"files": [
		"dist",
		"src"
	]
}
