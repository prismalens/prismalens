// =============================================================================
// PRISMALENS APPLICATION SCHEMA - PostgreSQL
// =============================================================================
//
// ARCHITECTURE: Incident-Centric Event Management
// ------------------------------------------------
// This schema follows industry patterns (PagerDuty, Datadog, BigPanda) for
// incident management, where multiple alerts are correlated into incidents.
//
// ENTITY RELATIONSHIP DIAGRAM:
// ============================
//
//   ┌─────────────┐
//   │   Service   │◄──────────────────────────────────────────┐
//   │  (catalog)  │                                           │
//   └──────┬──────┘                                           │
//          │ 1:N                                              │
//          ▼                                                  │
//   ┌─────────────┐     ┌─────────────┐     ┌─────────────┐  │
//   │    Event    │────►│    Alert    │────►│  Incident   │──┘
//   │   (raw)     │ 1:1 │ (deduped)   │ N:1 │ (correlated)│
//   └─────────────┘     └─────────────┘     └──────┬──────┘
//                                                  │ 1:N
//                              ┌───────────────────┼───────────────────┐
//                              ▼                   ▼                   ▼
//                       ┌─────────────┐     ┌─────────────┐     ┌─────────────┐
//                       │Investigation│     │  Timeline   │     │ Postmortem  │
//                       │  (AI work)  │     │  (log)      │     │ (learnings) │
//                       └──────┬──────┘     └─────────────┘     └─────────────┘
//                              │ 1:N
//                       ┌──────┴──────┐
//                       ▼             ▼
//                ┌─────────────┐ ┌─────────────┐
//                │   Agent     │ │Recommendation│
//                │ Execution   │ │             │
//                └──────┬──────┘ └─────────────┘
//                       │ 1:N
//                       ▼
//                ┌─────────────┐
//                │    Tool     │
//                │ Execution   │
//                └─────────────┘
//
// DATA FLOW:
// ==========
// 1. Webhook receives raw payload → creates Event (immutable)
// 2. Event is normalized → creates/updates Alert (deduplicated by dedupKey)
// 3. Alert is correlated → linked to existing or new Incident
// 4. AI worker investigates → creates Investigation with AgentExecutions
// 5. Investigation produces → Recommendations and updates Incident
//
// EDITION:
// ========
// Community Edition - Single organization, no multi-tenancy
// Enterprise Edition - Add organizationId to key models for multi-tenancy
//
// =============================================================================

// =============================================================================
// ENUMS
// =============================================================================

/// Service types for the service catalog
enum ServiceType {
  service // Application service
  database // Database (PostgreSQL, MySQL, etc.)
  queue // Message queue (Redis, RabbitMQ, etc.)
  cache // Cache layer (Redis, Memcached)
  gateway // API gateway, load balancer
  external // Third-party service
  infrastructure // Infrastructure component (K8s, VM)
}

/// Service tiers for prioritization
enum ServiceTier {
  tier_1 // Business critical, immediate response required
  tier_2 // Important, response within hours
  tier_3 // Standard, response within day
  tier_4 // Low priority, best effort
}

/// Dependency types between services
enum DependencyType {
  runtime // Runtime dependency (API calls)
  build // Build-time dependency
  data // Data dependency (shared DB)
}

/// Dependency criticality levels
enum DependencyCriticality {
  required // Service fails without dependency
  optional // Service degrades without dependency
  degraded // Service works but with reduced functionality
}

/// Severity levels for alerts and incidents
enum Severity {
  critical // System down, immediate action required
  high // Significant impact, action required soon
  medium // Moderate impact, schedule fix
  low // Minor issue, fix when convenient
  info // Informational, no action required
}

/// Alert status lifecycle
enum AlertStatus {
  triggered // Alert is active/firing
  acknowledged // Someone/something is looking at it
  correlated // Alert has been linked to an Incident
  resolved // Alert condition cleared
  suppressed // Manually suppressed/ignored
}

/// Incident status lifecycle
enum IncidentStatus {
  triggered // Incident created, awaiting investigation
  investigating // AI worker is analyzing
  identified // Root cause identified
  monitoring // Fix applied, monitoring for recurrence
  resolved // Incident resolved
  closed // Postmortem complete, incident closed
}

/// Priority levels for incidents
enum Priority {
  p1 // Immediate response required
  p2 // Response within 1 hour
  p3 // Response within 4 hours
  p4 // Response within 24 hours
  p5 // Best effort
}

/// Investigation/workflow status
enum WorkflowStatus {
  pending // Queued for analysis
  running // Agents are executing
  completed // Analysis finished successfully
  failed // Analysis failed with error
  cancelled // Cancelled by user or system
}

/// Root cause categories
enum RootCauseCategory {
  code // Bug in application code
  config // Configuration error
  infrastructure // Infrastructure issue
  external // Third-party/external cause
  unknown // Could not determine
}

/// Agent types
enum AgentType {
  llm // LLM-based agent
  sequential // Sequential workflow agent
  loop // Loop agent
}

/// Execution status for agents
enum ExecutionStatus {
  pending // Not started
  running // Currently executing
  completed // Finished successfully
  failed // Failed with error
}

/// Tool execution status
enum ToolExecutionStatus {
  pending // Not started
  running // Currently executing
  success // Completed successfully
  error // Failed with error
}

/// Tool categories
enum ToolCategory {
  file // File system operations
  search // Code search
  github // GitHub API
  logs // Log retrieval
  analysis // Analysis tools
}

/// Recommendation priority
enum RecommendationPriority {
  critical // Do this immediately
  high // Do this soon
  medium // Do when possible
  low // Nice to have
}

/// Recommendation categories
enum RecommendationCategory {
  code_fix // Code change required
  config_change // Configuration change
  rollback // Rollback deployment
  monitoring // Add/improve monitoring
  investigation // Further investigation needed
}

/// Recommendation urgency
enum Urgency {
  immediate // Do within minutes
  short_term // Do within hours
  long_term // Do within days/weeks
}

/// Effort estimates
enum EffortEstimate {
  minutes // Quick fix
  hours // Moderate effort
  days // Significant effort
}

/// Recommendation status
enum RecommendationStatus {
  pending // Not started
  in_progress // Being worked on
  completed // Implemented
  rejected // Decided not to implement
  deferred // Postponed for later
}

/// Timeline entry types
enum TimelineEntryType {
  incident_created
  alert_added
  alert_removed
  status_changed
  severity_changed
  assigned
  investigation_started
  investigation_completed
  recommendation_added
  recommendation_completed
  comment
  postmortem_created
  custom
}

/// Timeline entry source
enum TimelineSource {
  system // Automatically generated
  user // Created by user
  ai_worker // Created by AI worker
}

/// Postmortem status
enum PostmortemStatus {
  draft // Being written
  in_review // Under review
  published // Finalized and shared
  archived // No longer active
}

/// Correlation rule actions
enum CorrelationAction {
  correlate // Add alert to existing incident (or create new)
  suppress // Suppress the alert (don't create incident)
  create_incident // Always create a new incident
}

/// Setting value types
enum SettingType {
  string // Plain string value
  number // Numeric value
  boolean // Boolean value
  json // Complex JSON object
  encrypted // Encrypted value (AES-256-GCM)
}

/// Setting categories
enum SettingCategory {
  general // General settings
  correlation // Correlation settings
  ai // AI/LLM settings
  notifications // Notification settings
  setup // Setup wizard settings
}

/// Investigation trigger types
enum InvestigationTriggerType {
  manual // User clicks "Investigate" button
  auto_critical // Auto-triggered for critical severity
  auto_tier // Auto-triggered based on service tier
  alert_threshold // Auto-triggered when alert count exceeds threshold
  scheduled // Auto-triggered for stale incidents
  re_trigger // Re-triggered when new alerts are added
}

/// Change event types for correlation
enum ChangeEventType {
  deployment // Application deployment
  config // Configuration change
  migration // Database migration
  commit // Code commit
  rollback // Rollback of deployment
}

/// Integration connection status
enum ConnectionStatus {
  pending // Not yet connected
  connected // Successfully connected
  error // Connection error
  disabled // Manually disabled
}

/// Authentication methods
enum AuthMethod {
  api_key // API key authentication
  oauth2 // OAuth 2.0 authentication
}

/// Service suggestion status
enum SuggestionStatus {
  pending // Awaiting user decision
  accepted // User accepted the suggestion
  rejected // User rejected the suggestion
  ignored // User chose to ignore
}

// =============================================================================
// SERVICE CATALOG
// =============================================================================
// Services represent monitored components - "what can break".
// Used for:
// - Linking alerts/incidents to affected systems
// - Topology-based correlation (if Service A depends on B, correlate alerts)
// - Code analysis (repository link for AI investigation)
// =============================================================================

/// Service represents a monitored component (API, database, queue, etc.)
/// Services form the backbone of topology-aware incident correlation.
model Service {
  id           String      @id @default(uuid())
  name         String      @unique // Unique identifier, e.g., "api-gateway", "user-service"
  displayName  String? // Human-readable name, e.g., "API Gateway"
  description  String?
  type         ServiceType @default(service)
  tier         ServiceTier @default(tier_3)
  team         String? // Team responsible for this service
  slackChannel String? // Slack channel for notifications
  repository   String? // GitHub repo, e.g., "org/repo-name" (for AI code analysis)
  tags         String? // JSON array: ["backend", "critical", "payments"]
  metadata     String? // JSON object for custom fields: {"oncall": "team-a", "runbook": "..."}

  // Discovery metadata
  discoverySource   String? // "github", "manual", etc.
  discoveryMetadata String? // JSON: { "owner": "org", "repo": "name", "isMonorepo": false }
  isDiscovered      Boolean @default(false) // true = auto-discovered, false = manually created
  isConfirmed       Boolean @default(true) // false = pending user confirmation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  alerts            Alert[]
  incidents         Incident[]
  dependencies      ServiceDependency[]  @relation("DependentService")
  dependents        ServiceDependency[]  @relation("DependencyService")
  integrations      ServiceIntegration[]
  alertMappingRules AlertMappingRule[]
  changeEvents      ChangeEvent[]

  @@map("services")
}

/// Service dependency for topology-based correlation.
/// Example: If "api-gateway" depends on "user-service", an incident on
/// "user-service" may explain alerts from "api-gateway".
model ServiceDependency {
  id             String                @id @default(uuid())
  dependentId    String // The service that DEPENDS ON another
  dependencyId   String // The service BEING DEPENDED UPON
  dependencyType DependencyType        @default(runtime)
  criticality    DependencyCriticality @default(required)
  createdAt      DateTime              @default(now())

  dependent  Service @relation("DependentService", fields: [dependentId], references: [id], onDelete: Cascade)
  dependency Service @relation("DependencyService", fields: [dependencyId], references: [id], onDelete: Cascade)

  @@unique([dependentId, dependencyId])
  @@map("service_dependencies")
}

// =============================================================================
// EVENTS - RAW INCOMING SIGNALS
// =============================================================================
// Events are immutable records of raw signals from monitoring systems.
// They capture the original payload before any processing.
// Multiple events may be deduplicated into a single Alert.
// =============================================================================

/// Raw event from monitoring systems (Prometheus, GitHub, Render, etc.)
/// Events are immutable - they capture exactly what was received.
model Event {
  id            String    @id @default(uuid())
  source        String // Source system: "prometheus", "github", "render", "generic"
  sourceEventId String? // ID from source system for deduplication
  eventType     String // Event type: "alert", "deployment", "commit", "incident"
  payload       String // Full raw JSON payload (stored as string)
  receivedAt    DateTime  @default(now())
  eventTime     DateTime? // When the event actually occurred (from payload)
  processed     Boolean   @default(false)
  alertId       String? // The Alert created from this event (after processing)

  alert Alert? @relation(fields: [alertId], references: [id])

  @@index([source, sourceEventId])
  @@index([receivedAt])
  @@index([processed])
  @@map("events")
}

// =============================================================================
// ALERTS - DEDUPLICATED, NORMALIZED SIGNALS
// =============================================================================
// Alerts are deduplicated, normalized events with state tracking.
// Key concepts:
// - dedupKey: Hash for deduplication (same key = same alert, increment count)
// - fingerprint: Content similarity hash (for finding related alerts)
// - Multiple alerts can be correlated into one Incident
// =============================================================================

/// Deduplicated, normalized alert from monitoring events.
/// Alerts have a simple lifecycle: triggered → acknowledged → resolved
model Alert {
  id              String      @id @default(uuid())
  dedupKey        String      @unique // Hash of (source + title + severity) for deduplication
  fingerprint     String? // Content fingerprint for similarity matching
  externalId      String?     @unique // Original ID from source system
  title           String
  description     String?
  severity        Severity    @default(medium)
  status          AlertStatus @default(triggered)
  source          String? // Source system: "prometheus", "github", "render"
  sourceUrl       String? // Link back to source system
  serviceId       String? // The Service this alert relates to
  tags            String? // JSON array for correlation: ["database", "timeout"]
  labels          String? // JSON object of key-value labels: {"env": "prod", "region": "us-east"}
  triggeredAt     DateTime    @default(now())
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  occurrenceCount Int         @default(1) // How many times this dedupKey has fired
  lastOccurrence  DateTime    @default(now()) // Most recent occurrence
  rawPayload      String? // Original payload JSON (for debugging)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  service    Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  incidentId String? // The Incident this alert is correlated to
  incident   Incident? @relation(fields: [incidentId], references: [id])
  events     Event[] // Raw events that created/updated this alert

  @@index([status])
  @@index([severity])
  @@index([serviceId])
  @@index([incidentId])
  @@index([triggeredAt])
  @@index([fingerprint])
  @@map("alerts")
}

// =============================================================================
// INCIDENTS - CORRELATED ALERTS (THE MAIN WORK UNIT)
// =============================================================================
// Incidents are the primary entity for incident management.
// They represent a single business problem that may involve multiple alerts.
// AI workers operate at the Incident level (not individual alerts).
// =============================================================================

/// Incident - correlated alerts representing a single business problem.
/// This is the main work unit in PrismaLens. AI workers investigate incidents.
model Incident {
  id                String         @id @default(uuid())
  number            Int            @unique @default(autoincrement()) // Human-readable: INC-123
  title             String
  description       String?
  severity          Severity       @default(medium)
  status            IncidentStatus @default(triggered)
  priority          Priority       @default(p3)
  serviceId         String? // Primary affected service
  assignedToId      String? // User assigned for visibility (not for paging)
  correlationReason String? // Why alerts were grouped: "same_service", "time_window", "rule:xyz"
  correlationRuleId String? // Which CorrelationRule matched (if any)
  tags              String? // JSON array: ["database", "outage"]
  customerImpact    String? // Description of customer impact
  affectedSystems   String? // JSON array: ["checkout", "payments"]
  triggeredAt       DateTime       @default(now())
  acknowledgedAt    DateTime?
  resolvedAt        DateTime?
  alertCount        Int            @default(0) // Number of correlated alerts
  timeToAcknowledge Int? // Seconds from triggered to acknowledged
  timeToResolve     Int? // Seconds from triggered to resolved
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relations
  service         Service?         @relation(fields: [serviceId], references: [id])
  assignedTo      User?            @relation("AssignedTo", fields: [assignedToId], references: [id])
  correlationRule CorrelationRule? @relation(fields: [correlationRuleId], references: [id])
  alerts          Alert[] // All alerts correlated to this incident
  investigations  Investigation[] // AI investigations of this incident
  timeline        TimelineEntry[] // Activity log
  postmortem      Postmortem? // Post-incident analysis (1:1)

  @@index([status])
  @@index([severity])
  @@index([priority])
  @@index([serviceId])
  @@index([triggeredAt])
  @@map("incidents")
}

// =============================================================================
// INVESTIGATION - AI WORKER ANALYSIS
// =============================================================================
// Investigation is the AI-driven analysis of an incident.
// It tracks the multi-agent workflow and produces recommendations.
// AgentExecution and ToolExecution provide full observability.
// =============================================================================

/// AI-driven investigation of an incident.
/// Each investigation runs the multi-agent workflow (Alert → Gatherer → Analyzer → Recommender).
model Investigation {
  id                String             @id @default(uuid())
  incidentId        String
  status            WorkflowStatus     @default(pending)
  startedAt         DateTime?
  completedAt       DateTime?
  summary           String? // Executive summary of findings
  rootCause         String? // Identified root cause
  rootCauseCategory RootCauseCategory?
  confidence        Float? // Overall confidence score (0.0 to 1.0)
  dataQuality       String? // JSON: {"logs": 0.8, "code": 0.9, "metrics": 0.3}
  dataSourcesUsed   String? // JSON array: ["logs", "code", "github"]
  rawOutput         String? // Full agent workflow output (JSON) for debugging
  error             String? // Error message if status is "failed"
  langGraphThreadId String?            @unique // LangGraph checkpoint thread ID for resume/replay
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Trigger tracking
  triggerType   InvestigationTriggerType?
  triggerReason String?

  // Relations
  incident        Incident         @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  agentExecutions AgentExecution[] // Execution records for each agent
  recommendations Recommendation[] // Recommendations produced

  @@index([incidentId])
  @@index([status])
  @@map("investigations")
}

/// Agent execution within an investigation.
/// Tracks each agent's contribution to the analysis (Alert, Gatherer, Analyzer, Recommender).
model AgentExecution {
  id              String          @id @default(uuid())
  investigationId String
  agentName       String // Agent identifier (extensible - not an enum)
  agentType       AgentType       @default(llm)
  status          ExecutionStatus @default(pending)
  startedAt       DateTime?
  completedAt     DateTime?
  executionTimeMs Int? // Execution time in milliseconds
  output          String? // JSON output from agent
  confidence      Float? // Agent's confidence in its output (0.0 to 1.0)
  inputTokens     Int? // LLM input tokens (for cost tracking)
  outputTokens    Int? // LLM output tokens (for cost tracking)
  error           String? // Error message if failed
  createdAt       DateTime        @default(now())

  // Relations
  investigation  Investigation   @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  toolExecutions ToolExecution[] // Tools called by this agent

  @@index([investigationId])
  @@index([agentName])
  @@map("agent_executions")
}

/// Tool execution within an agent execution.
/// Tracks each tool call with arguments, results, and timing.
model ToolExecution {
  id               String              @id @default(uuid())
  agentExecutionId String
  toolName         String // Tool identifier
  // Common toolName values: "search_and_preview" - Search codebase
  //                         "read_file"          - Read file contents
  //                         "call_github_api"    - GitHub API call
  //                         "call_log_retriever_agent" - Log retrieval
  //                         "analyze_root_cause" - Root cause analysis
  toolCategory     ToolCategory? // Category for grouping
  arguments        String? // JSON of tool arguments
  result           String? // JSON of tool result (may be truncated)
  status           ToolExecutionStatus @default(pending)
  executionTimeMs  Int? // Execution time in milliseconds
  confidence       Float? // Confidence in result quality (0.0 to 1.0)
  dataQuality      String? // Assessment of data quality
  error            String? // Error message if failed
  executedAt       DateTime            @default(now())

  // Relations
  agentExecution AgentExecution @relation(fields: [agentExecutionId], references: [id], onDelete: Cascade)

  @@index([agentExecutionId])
  @@index([toolName])
  @@map("tool_executions")
}

// =============================================================================
// RECOMMENDATIONS - ACTIONABLE SOLUTIONS
// =============================================================================
// Recommendations are generated by the AI worker during investigation.
// They represent actionable solutions to resolve the incident.
// =============================================================================

/// Recommendation for resolving an incident.
/// Generated by the Recommender agent during investigation.
model Recommendation {
  id              String                  @id @default(uuid())
  investigationId String
  title           String
  description     String?
  priority        RecommendationPriority  @default(medium)
  category        RecommendationCategory?
  urgency         Urgency?
  actionable      Boolean                 @default(true) // Is this actionable or informational?
  estimatedEffort EffortEstimate?
  status          RecommendationStatus    @default(pending)
  implementedAt   DateTime?
  implementedBy   String? // User ID or "ai_worker" if auto-implemented
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  // Relations
  investigation Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@index([status])
  @@index([priority])
  @@map("recommendations")
}

// =============================================================================
// TIMELINE - INCIDENT ACTIVITY LOG
// =============================================================================
// Timeline tracks all activities on an incident for audit and visibility.
// Entries are created automatically by the system and manually by users.
// =============================================================================

/// Timeline entry for tracking incident activity.
/// Provides a complete audit trail of what happened during an incident.
model TimelineEntry {
  id          String            @id @default(uuid())
  incidentId  String
  type        TimelineEntryType
  title       String
  description String?
  metadata    String? // JSON for additional context: {"old_status": "...", "new_status": "..."}
  source      TimelineSource    @default(system)
  userId      String? // User who created this entry (if source is "user")
  occurredAt  DateTime          @default(now())

  // Relations
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@index([incidentId])
  @@index([occurredAt])
  @@map("timeline_entries")
}

// =============================================================================
// POSTMORTEM - POST-INCIDENT ANALYSIS
// =============================================================================
// Postmortems capture learnings after incident resolution.
// They help prevent similar incidents in the future.
// =============================================================================

/// Postmortem for post-incident analysis and learnings.
/// Created after incident resolution to capture what happened and what to improve.
model Postmortem {
  id              String           @id @default(uuid())
  incidentId      String           @unique // One postmortem per incident
  title           String?
  summary         String? // Executive summary
  timeline        String? // JSON array: [{"timestamp": "...", "event": "...", "impact": "..."}]
  whatHappened    String? // Detailed description of what went wrong
  whyItHappened   String? // Root cause analysis
  whatWeLearned   String? // Key learnings
  actionItems     String? // JSON array: [{"title": "...", "owner": "...", "dueDate": "...", "status": "..."}]
  customerImpact  String? // Description of customer impact
  financialImpact Float? // Estimated financial impact
  status          PostmortemStatus @default(draft)
  authorId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  publishedAt     DateTime?

  // Relations
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  author   User?    @relation("PostmortemAuthor", fields: [authorId], references: [id])

  @@map("postmortems")
}

// =============================================================================
// CHANGE TRACKING - FOR CHANGE CORRELATION (BigPanda Pattern)
// =============================================================================
// Change events track deployments, config changes, and other changes that
// may correlate with incidents. 60-90% of incidents are change-related.
// =============================================================================

/// Change event for correlation with incidents.
/// Tracks deployments, commits, config changes that may cause incidents.
model ChangeEvent {
  id          String          @id @default(uuid())
  type        ChangeEventType
  source      String // render, github, manual, argocd, etc.
  timestamp   DateTime
  serviceId   String?
  description String?
  metadata    String? // JSON: { version, environment, author, url, etc. }
  riskScore   Int? // 0-100, calculated based on time proximity and change type

  createdAt DateTime @default(now())

  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([serviceId, timestamp])
  @@index([timestamp])
  @@index([type])
  @@map("change_events")
}

// =============================================================================
// SIMILAR INCIDENT TRACKING - FOR PATTERN MATCHING (BigPanda 30% Threshold)
// =============================================================================
// Track similarity between incidents for pattern detection and
// providing resolution hints based on past incidents.
// =============================================================================

/// Incident similarity record for pattern matching.
/// Pre-calculated similarity scores for faster lookups.
model IncidentSimilarity {
  id                String   @id @default(uuid())
  incidentId        String // Current incident
  similarIncidentId String // Similar past incident
  similarityScore   Int // 0-100 (BigPanda uses 30% threshold)
  matchFactors      String? // JSON: { titleMatch, serviceMatch, tagMatch, etc. }
  calculatedAt      DateTime @default(now())

  @@unique([incidentId, similarIncidentId])
  @@index([incidentId])
  @@index([similarIncidentId])
  @@index([similarityScore])
  @@map("incident_similarities")
}

// =============================================================================
// CORRELATION RULES - ALERT-TO-INCIDENT MATCHING
// =============================================================================
// Correlation rules define how alerts are grouped into incidents.
// Rules are evaluated in priority order (lower number = higher priority).
// AI can also decide correlation based on similarity.
// =============================================================================

/// Correlation rule for grouping alerts into incidents.
/// Rules define conditions for when alerts should be correlated together.
model CorrelationRule {
  id                String            @id @default(uuid())
  name              String            @unique
  description       String?
  enabled           Boolean           @default(true)
  priority          Int               @default(100) // Lower = higher priority (evaluated first)
  matchCriteria     String // JSON defining match conditions
  // matchCriteria example: {
  //   "match": {
  //     "tags": ["database"],      // Alert must have these tags
  //     "severity": ["critical", "high"], // Alert must have one of these severities
  //     "service": "user-service"  // Alert must be for this service
  //   }
  // }
  timeWindowMinutes Int               @default(60) // Group alerts within this time window
  action            CorrelationAction @default(correlate)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  incidents Incident[] // Incidents created/matched by this rule

  @@map("correlation_rules")
}

// =============================================================================
// SETTINGS - SYSTEM CONFIGURATION
// =============================================================================
// Key-value settings for system configuration.
// Used for storing configuration that doesn't fit in environment variables.
// =============================================================================

/// System settings and configuration.
/// Stores key-value pairs for runtime configuration.
model Setting {
  id          String           @id @default(uuid())
  key         String           @unique
  value       String // Value stored as JSON string
  type        SettingType      @default(string)
  category    SettingCategory?
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("settings")
}

// =============================================================================
// INTEGRATIONS - EXTERNAL TOOL CONNECTIONS
// =============================================================================
// Integration system for connecting external tools (GitHub, Prometheus, Slack).
// Follows n8n-style credential management: OAuth credentials stored in DB (encrypted),
// not in environment variables. Only PRISMALENS_ENCRYPTION_KEY env var required.
//
// HIERARCHY:
//   IntegrationDefinition (catalog) - Admin configures OAuth app credentials here
//     └── IntegrationConnection (user instance) - User's tokens/API keys
//           └── ServiceIntegration (service mapping) - Optional service-level overrides
// =============================================================================

/// Integration catalog - available integration types (github, prometheus, slack)
/// Admin can configure OAuth app credentials (clientId/clientSecret) here.
model IntegrationDefinition {
  id               String   @id @default(uuid())
  name             String   @unique // Identifier: "github", "prometheus", "slack"
  displayName      String // Human-readable: "GitHub", "Prometheus", "Slack"
  description      String?
  category         String // Category: "monitoring" | "code_source" | "knowledge_base"
  authType         String // Authentication type: "api_key", "oauth2", "both"
  configSchema     String? // JSON Schema for config fields
  oauthConfig      String? // Encrypted JSON: { clientId, clientSecret, scopes, authUrl, tokenUrl }
  iconUrl          String?
  docsUrl          String?
  maxConnectionsCE Int? // null = unlimited, 1 = single connection in CE
  isEnabled        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  connections IntegrationConnection[]

  @@map("integration_definitions")
}

/// User-configured integration instance.
/// Stores encrypted credentials (API keys or OAuth tokens).
model IntegrationConnection {
  id              String           @id @default(uuid())
  definitionId    String
  name            String // User-friendly name, e.g., "Production GitHub"
  description     String?
  isGlobal        Boolean          @default(true) // Available to all services if true
  status          ConnectionStatus @default(pending)
  lastHealthCheck DateTime?
  lastError       String?
  authMethod      AuthMethod // api_key or oauth2
  credentials     String // Encrypted JSON: { apiKey } or { accessToken, refreshToken, expiresAt }
  config          String? // JSON: { baseUrl, org, defaultChannel, etc. }
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  definition         IntegrationDefinition @relation(fields: [definitionId], references: [id])
  serviceMappings    ServiceIntegration[]
  serviceSuggestions ServiceSuggestion[]

  @@unique([definitionId, name])
  @@index([status])
  @@map("integration_connections")
}

/// Service-to-integration mapping (optional service-level overrides).
/// Allows configuring specific repos, channels, etc. per service.
model ServiceIntegration {
  id           String   @id @default(uuid())
  serviceId    String
  connectionId String
  priority     Int      @default(0) // Higher priority connections used first
  config       String? // Service-specific overrides: { repo, channel, alertGroup, etc. }
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  service    Service               @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  connection IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([serviceId, connectionId])
  @@index([serviceId])
  @@index([connectionId])
  @@map("service_integrations")
}

// =============================================================================
// ALERT MAPPING RULES - MAP ALERTS TO SERVICES
// =============================================================================
// Alert mapping rules define how incoming alerts are routed to services.
// Rules are evaluated in priority order (lower number = higher priority).
// =============================================================================

/// Alert mapping rule for routing incoming alerts to services.
/// Allows matching alerts based on labels, tags, source, or title patterns.
model AlertMappingRule {
  id          String  @id @default(uuid())
  name        String
  description String?
  priority    Int     @default(100) // Lower = higher priority
  enabled     Boolean @default(true)

  // Match conditions (JSON)
  // Example: { "labels": {"app": "api-*"}, "source": "prometheus" }
  matchCriteria String

  // Target service
  serviceId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([priority])
  @@index([enabled])
  @@index([serviceId])
  @@map("alert_mapping_rules")
}

// =============================================================================
// SERVICE SUGGESTIONS - PENDING SERVICE DISCOVERIES
// =============================================================================
// Service suggestions are created when services are auto-discovered from
// code repositories. Users can accept/reject suggestions to create Services.
// =============================================================================

/// Service suggestion from auto-discovery.
/// Pending service discoveries awaiting user confirmation.
model ServiceSuggestion {
  id            String           @id @default(uuid())
  connectionId  String // Which IntegrationConnection discovered this
  suggestedName String
  displayName   String?
  repository    String // "owner/repo"
  isMonorepo    Boolean          @default(false)
  subPath       String? // For monorepo: "packages/api"
  status        SuggestionStatus @default(pending)
  metadata      String? // JSON with additional discovery info
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  connection IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, repository, subPath])
  @@index([status])
  @@index([connectionId])
  @@map("service_suggestions")
}

// =============================================================================
// LICENSE MANAGEMENT
// =============================================================================
// License management for feature gating and quota enforcement.
// Supports multiple license types:
// - none: Free tier, no license key required
// - perpetual: Free+License tier, never expires
// - subscription: Paid tiers (Beginner, Team, Business, Enterprise)
//
// License validation:
// - Perpetual: Validate once at activation, cached indefinitely
// - Subscription: Periodic validation (daily sync with license server)
//
// Expiry behavior:
// - Perpetual: Never expires
// - Subscription: Read-only mode on expiry (can view, cannot create)
// =============================================================================

/// License type for determining validation and expiry behavior
enum LicenseType {
  none // Community, no license key needed
  subscription // Enterprise, time-limited
}

/// License tier for feature entitlements
enum LicenseTier {
  community // Open-source, basic features
  enterprise // Full features, SSO, advanced integrations
}

/// License information for the installation.
/// Stores license key, entitlements, quotas, and validation state.
/// Only one active license per installation (Community Edition is single-tenant).
model LicenseInfo {
  id String @id @default(uuid())

  // License identification
  licenseKey  String?     @unique // The license key from Keygen.sh
  licenseType LicenseType @default(none)
  tier        LicenseTier @default(community)

  // Validity and activation
  validUntil    DateTime? // null for perpetual, set for subscription
  activatedAt   DateTime? // When the license was first activated
  lastValidated DateTime? // Last successful validation with license server

  // Entitlements (from Keygen policy)
  features String @default("[]") // JSON array: ["feat:extended_agents", "feat:sso", ...]
  quotas   String @default("{}") // JSON object: {"investigations_monthly": 500, ...}

  // Subscription-specific (for future use)
  billingCycle String? // "monthly", "annual" (null for perpetual)
  seats        Int? // null for unlimited, set for seat-based tiers

  // Cloud-hosted specific (for future cloud tiers)
  cloudInstanceId String? // Links to cloud deployment (pre-configured licenses)
  isCloudManaged  Boolean @default(false) // true = license managed by cloud, user never sees key

  // Customer metadata
  customerEmail String?
  customerName  String?
  metadata      String  @default("{}") // JSON for additional data from license server

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("license_info")
}
