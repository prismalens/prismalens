// =============================================================================
// PRISMALENS INTEGRATIONS SCHEMA - SQLite
// =============================================================================
// NOTE: SQLite does not support native enums. All enum fields are String types
// with comments documenting valid values.
//
// Three-layer integration architecture:
//   Integration (OAuth client creds) → Connection (user tokens) → ServiceIntegration (per-service mapping)
// Templates are in TypeScript code (@prismalens/integrations), not DB rows.
// =============================================================================

// =============================================================================
// INTEGRATION - OAuth app credentials (admin-configured)
// =============================================================================

/// Integration represents an admin-configured provider instance.
model Integration {
  id              String   @id @default(uuid())
  tenantId        String?  // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  templateId      String   // References AuthTemplate.id from @prismalens/integrations
  templateVersion String?  // Template semver at creation time (e.g., "1.0.0")
  label           String   // User-friendly name
  clientIdEnc     Bytes?   // Encrypted OAuth client ID (null for api_key/basic)
  clientSecretEnc Bytes?   // Encrypted OAuth client secret (null for api_key/basic)
  scopes          String   @default("[]") // JSON array of OAuth scopes
  callbackUrl     String?  // OAuth callback URL
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  connections Connection[]

  @@index([templateId])
  @@map("integrations")
}

// =============================================================================
// CONNECTION - User tokens / API keys
// =============================================================================

/// Connection stores a user's encrypted credentials for an integration.
model Connection {
  id                  String   @id @default(uuid())
  tenantId            String?  // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  integrationId       String
  label               String   @default("") // User-friendly name to distinguish multiple connections
  userId              String
  organizationId      String?
  connectionConfigEnc Bytes?   // Encrypted connection-specific config
  credentialsEnc      Bytes    // Encrypted credentials JSON
  tokenExpiresAt      DateTime?
  tokenType           String?
  grantedScopes       String   @default("[]") // JSON array of granted scopes
  metadataEnc         Bytes?   // Encrypted provider metadata
  status              String   @default("ACTIVE") // ACTIVE, TOKEN_EXPIRED, REFRESH_FAILED, CREDENTIALS_INVALID, REVOKED, ERROR
  lastUsedAt          DateTime?
  lastRefreshedAt     DateTime?
  lastErrorMessage    String?
  lastErrorAt         DateTime?
  consecutiveErrors   Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  integration        Integration          @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  serviceMappings    ServiceIntegration[]
  serviceSuggestions ServiceSuggestion[]
  repositories       Repository[]
  deployments        Deployment[]

  @@index([integrationId, userId])
  @@index([userId])
  @@index([status])
  @@index([tokenExpiresAt])
  @@map("connections")
}

// =============================================================================
// OAUTH STATE - CSRF protection for OAuth flows
// =============================================================================

/// Temporary OAuth state for CSRF protection during authorization flow.
model OAuthState {
  id                  String   @id @default(uuid())
  state               String   @unique
  integrationId       String
  userId              String
  organizationId      String?
  callbackUrl         String
  connectionConfigEnc Bytes?
  codeVerifier        String?
  metadata            String?  // JSON (SQLite has no native Json type)
  expiresAt           DateTime
  createdAt           DateTime @default(now())

  @@index([state])
  @@index([expiresAt])
  @@map("oauth_states")
}

// =============================================================================
// SERVICE INTEGRATION - Per-service overrides
// =============================================================================

/// Service-to-connection mapping with optional per-service config overrides.
model ServiceIntegration {
  id           String   @id @default(uuid())
  serviceId    String
  connectionId String
  priority     Int      @default(0)
  config       String?  // Service-specific overrides JSON
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  service    Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([serviceId, connectionId])
  @@index([serviceId])
  @@index([connectionId])
  @@map("service_integrations")
}

// =============================================================================
// SERVICE SUGGESTION - Auto-discovered services
// =============================================================================

/// Service suggestion from auto-discovery.
model ServiceSuggestion {
  id                   String    @id @default(uuid())
  connectionId         String
  suggestedName        String
  displayName          String?
  repository           String    // "owner/repo" for VCS, provider service name for deployments
  isMonorepo           Boolean   @default(false)
  subPath              String?
  sourceType           String    @default("repository") // "repository" | "deployment"
  status               String    @default("pending") // pending, accepted, rejected, ignored
  metadata             String?   // JSON
  statusChangedAt      DateTime?
  acceptedServiceId    String?
  acceptedDeploymentId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  connection         Connection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  acceptedService    Service?    @relation(fields: [acceptedServiceId], references: [id], onDelete: SetNull)
  acceptedDeployment Deployment? @relation(fields: [acceptedDeploymentId], references: [id], onDelete: SetNull)

  @@unique([connectionId, repository, subPath])
  @@index([status])
  @@index([connectionId])
  @@index([acceptedServiceId])
  @@index([acceptedDeploymentId])
  @@map("service_suggestions")
}
