// =============================================================================
// PRISMALENS APPLICATION SCHEMA - SQLite
// =============================================================================
//
// NOTE: SQLite does not support native enums. All enum fields are String types
// with comments documenting valid values.
//
// ARCHITECTURE: Incident-Centric Event Management
// ------------------------------------------------
// This schema follows industry patterns (PagerDuty, Datadog, BigPanda) for
// incident management, where multiple alerts are correlated into incidents.
//
// =============================================================================

// =============================================================================
// SERVICE CATALOG
// =============================================================================

/// Service represents a monitored component (API, database, queue, etc.)
/// A Service is a pure logical entity — source tracking lives in Repository and Deployment.
model Service {
  id           String  @id @default(uuid())
  tenantId     String? // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  name         String  @unique
  displayName  String?
  description  String?
  type         String  @default("service") // service, database, queue, cache, gateway, external, infrastructure
  tier         String  @default("tier_3") // tier_1, tier_2, tier_3, tier_4
  team         String?
  slackChannel String?
  tags              String? // JSON array
  metadata          String? // JSON object
  discoveryMetadata String? // JSON object — populated during service discovery

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alerts            Alert[]
  incidents         Incident[]
  dependencies      ServiceDependency[]  @relation("DependentService")
  dependents        ServiceDependency[]  @relation("DependencyService")
  integrations      ServiceIntegration[]
  alertMappingRules AlertMappingRule[]
  changeEvents      ChangeEvent[]
  repositories         ServiceRepository[]
  deployments          Deployment[]
  acceptedSuggestions  ServiceSuggestion[]

  @@map("services")
}

/// Repository represents a code source from a VCS provider
model Repository {
  id            String   @id @default(uuid())
  tenantId      String?  // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  connectionId  String
  fullName      String               // "org/repo"
  url           String               // "https://github.com/org/repo"
  description   String?
  language      String?
  defaultBranch String   @default("main")
  isPrivate     Boolean  @default(false)
  metadata      String?              // JSON — stars, topics, etc.
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  connection    Connection          @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  services      ServiceRepository[]

  @@unique([connectionId, fullName])
  @@map("repositories")
}

/// Junction table linking Services to Repositories (M:N with subPath for monorepos)
model ServiceRepository {
  id            String   @id @default(uuid())
  serviceId     String
  repositoryId  String
  subPath       String?              // "packages/api" for monorepos
  isPrimary     Boolean  @default(true)
  createdAt     DateTime @default(now())

  service       Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  repository    Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([serviceId, repositoryId, subPath])
  @@map("service_repositories")
}

/// Deployment represents a running instance from a deployment platform
model Deployment {
  id              String    @id @default(uuid())
  tenantId        String?   // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  serviceId       String?
  connectionId    String
  externalId      String
  name            String
  url             String?
  status          String?              // "live", "suspended", etc.
  environment     String?              // "production", "staging"
  deploymentType  String?              // "web_service", "worker", "cron_job", "static_site"
  region          String?
  branch          String?
  repositoryUrl   String?
  metadata        String?              // JSON
  lastDeployedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  service            Service?            @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  connection         Connection          @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  acceptedSuggestion ServiceSuggestion[]

  @@unique([connectionId, externalId])
  @@map("deployments")
}

/// Service dependency for topology-based correlation
model ServiceDependency {
  id             String   @id @default(uuid())
  dependentId    String
  dependencyId   String
  dependencyType String   @default("runtime") // runtime, build, data
  criticality    String   @default("required") // required, optional, degraded
  createdAt      DateTime @default(now())

  dependent  Service @relation("DependentService", fields: [dependentId], references: [id], onDelete: Cascade)
  dependency Service @relation("DependencyService", fields: [dependencyId], references: [id], onDelete: Cascade)

  @@unique([dependentId, dependencyId])
  @@map("service_dependencies")
}

// =============================================================================
// EVENTS - RAW INCOMING SIGNALS
// =============================================================================

/// Raw event from monitoring systems (immutable)
model Event {
  id            String    @id @default(uuid())
  tenantId      String?   // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  source        String // prometheus, github, render, generic
  sourceEventId String?
  eventType     String // alert, deployment, commit
  payload       String // Full raw JSON
  receivedAt    DateTime  @default(now())
  eventTime     DateTime?
  processed     Boolean   @default(false)
  alertId       String?

  alert Alert? @relation(fields: [alertId], references: [id])

  @@index([source, sourceEventId])
  @@index([receivedAt])
  @@index([processed])
  @@map("events")
}

// =============================================================================
// ALERTS - DEDUPLICATED, NORMALIZED SIGNALS
// =============================================================================

/// Deduplicated, normalized alert
model Alert {
  id              String    @id @default(uuid())
  tenantId        String?   // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  dedupKey        String    @unique // Hash for deduplication
  fingerprint     String? // Content fingerprint for similarity
  externalId      String?   @unique
  title           String
  description     String?
  severity        String    @default("medium") // critical, high, medium, low, info
  status          String    @default("triggered") // triggered, acknowledged, correlated, resolved, suppressed
  source          String?
  sourceUrl       String?
  serviceId       String?
  tags            String? // JSON array
  labels          String? // JSON object
  triggeredAt     DateTime  @default(now())
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  occurrenceCount Int       @default(1)
  lastOccurrence  DateTime  @default(now())
  rawPayload      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  service    Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])
  events     Event[]

  @@index([status])
  @@index([severity])
  @@index([serviceId])
  @@index([incidentId])
  @@index([triggeredAt])
  @@index([fingerprint])
  @@map("alerts")
}

// =============================================================================
// INCIDENTS - CORRELATED ALERTS (THE MAIN WORK UNIT)
// =============================================================================

/// Incident - correlated alerts representing a single business problem
model Incident {
  id                String    @id @default(uuid())
  tenantId          String?   // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  number            Int       @unique // Managed by application (no autoincrement in SQLite)
  title             String
  description       String?
  severity          String    @default("medium") // critical, high, medium, low, info
  status            String    @default("triggered") // triggered, investigating, identified, monitoring, resolved, closed
  priority          String    @default("p3") // p1, p2, p3, p4, p5
  serviceId         String?
  assignedToId      String?
  correlationReason String?
  correlationRuleId String?
  tags              String? // JSON array
  customerImpact    String?
  affectedSystems   String? // JSON array
  triggeredAt       DateTime  @default(now())
  acknowledgedAt    DateTime?
  resolvedAt        DateTime?
  alertCount        Int       @default(0)
  timeToAcknowledge Int? // Seconds
  timeToResolve     Int? // Seconds
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  service         Service?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  assignedTo      User?            @relation("AssignedTo", fields: [assignedToId], references: [id])
  correlationRule CorrelationRule? @relation(fields: [correlationRuleId], references: [id])
  alerts          Alert[]
  investigations  Investigation[]
  timeline        TimelineEntry[]
  postmortem      Postmortem?

  @@index([status])
  @@index([severity])
  @@index([priority])
  @@index([serviceId])
  @@index([triggeredAt])
  @@map("incidents")
}

// =============================================================================
// INVESTIGATION - AI WORKER ANALYSIS
// =============================================================================

/// AI-driven investigation of an incident
model Investigation {
  id                String    @id @default(uuid())
  tenantId          String?   // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  incidentId        String
  status            String    @default("pending") // pending, running, completed, failed, cancelled
  startedAt         DateTime?
  completedAt       DateTime?
  summary           String?
  rootCause         String?
  rootCauseCategory String? // code, config, infrastructure, external, unknown
  report            String? // JSON: InvestigationReport
  overlay           String? // JSON: reduce overlay (ADR-0016 §5c) — app-side post-report enrichment, computed BESIDE the canonical report
  error             String?
  harnessThreadId   String?   @unique // Harness checkpoint thread ID for resume/replay
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Trigger tracking
  triggerType   String? // manual, auto_critical, auto_tier, alert_threshold, scheduled, re_trigger
  triggerReason String?

  incident        Incident             @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  agentExecutions AgentExecution[]
  recommendations Recommendation[]
  events          InvestigationEvent[]

  @@index([incidentId])
  @@index([status])
  @@map("investigations")
}

/// Durable server-side canonical event record (ADR-0018 store.append) — one row per
/// CanonicalEvent, the batched target that retired the worker store's no-op append.
/// Keyed idempotently by (investigationId, branchId, seq): (branchId, seq) is the
/// canonical stream's per-branch identity, so batch retries are no-ops. The
/// branchId-less terminal `report` event is stored under the "__report__" sentinel.
model InvestigationEvent {
  id              String   @id @default(uuid())
  investigationId String
  seq             Int // CanonicalEvent.seq (per-branch monotonic)
  branchId        String // CanonicalEvent.branchId; "__report__" for the terminal report event
  event           String // JSON: the full CanonicalEvent
  createdAt       DateTime @default(now())

  investigation Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@unique([investigationId, branchId, seq])
  @@index([investigationId, seq])
  @@map("investigation_events")
}

/// Agent execution within an investigation
model AgentExecution {
  id              String    @id @default(uuid())
  investigationId String
  agentName       String // alert_agent, gatherer_agent, analyzer_agent, recommender_agent
  agentType       String    @default("llm") // llm, sequential, loop
  status          String    @default("pending") // pending, running, completed, failed
  startedAt       DateTime?
  completedAt     DateTime?
  executionTimeMs Int?
  output          String? // JSON
  branchId        String?
  inputTokens     Int?
  outputTokens    Int?
  error           String?
  createdAt       DateTime  @default(now())

  investigation  Investigation   @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  toolExecutions ToolExecution[]

  @@index([investigationId])
  @@index([agentName])
  @@map("agent_executions")
}

/// Tool execution within an agent execution
model ToolExecution {
  id               String   @id @default(uuid())
  agentExecutionId String
  toolName         String
  toolCategory     String? // file, search, github, logs, analysis
  arguments        String? // JSON
  result           String? // JSON
  status           String   @default("pending") // pending, running, success, error
  executionTimeMs  Int?
  dataQuality      String?
  error            String?
  executedAt       DateTime @default(now())

  agentExecution AgentExecution @relation(fields: [agentExecutionId], references: [id], onDelete: Cascade)

  @@index([agentExecutionId])
  @@index([toolName])
  @@map("tool_executions")
}

// =============================================================================
// RECOMMENDATIONS - ACTIONABLE SOLUTIONS
// =============================================================================

/// Recommendation for resolving an incident
model Recommendation {
  id              String    @id @default(uuid())
  investigationId String
  title           String
  description     String?
  priority        String    @default("medium") // critical, high, medium, low
  category        String? // code_fix, config_change, rollback, monitoring, investigation
  urgency         String? // immediate, short_term, long_term
  actionable      Boolean   @default(true)
  estimatedEffort String? // minutes, hours, days
  status          String    @default("pending") // pending, in_progress, completed, rejected, deferred
  implementedAt   DateTime?
  implementedBy   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  investigation Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@index([status])
  @@index([priority])
  @@map("recommendations")
}

// =============================================================================
// TIMELINE - INCIDENT ACTIVITY LOG
// =============================================================================

/// Timeline entry for tracking incident activity
model TimelineEntry {
  id          String   @id @default(uuid())
  incidentId  String
  type        String // incident_created, alert_added, status_changed, etc.
  title       String
  description String?
  metadata    String? // JSON
  source      String   @default("system") // system, user, ai_worker
  userId      String?
  occurredAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@index([incidentId])
  @@index([occurredAt])
  @@map("timeline_entries")
}

// =============================================================================
// POSTMORTEM - POST-INCIDENT ANALYSIS
// =============================================================================

/// Postmortem for post-incident learnings
model Postmortem {
  id              String    @id @default(uuid())
  tenantId        String?   // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  incidentId      String    @unique
  title           String?
  summary         String?
  timeline        String? // JSON array
  whatHappened    String?
  whyItHappened   String?
  whatWeLearned   String?
  actionItems     String? // JSON array
  customerImpact  String?
  financialImpact Float?
  status          String    @default("draft") // draft, in_review, published, archived
  authorId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  publishedAt     DateTime?

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  author   User?    @relation("PostmortemAuthor", fields: [authorId], references: [id])

  @@map("postmortems")
}

// =============================================================================
// CHANGE TRACKING - FOR CHANGE CORRELATION (BigPanda Pattern)
// =============================================================================
// Change events track deployments, config changes, and other changes that
// may correlate with incidents. 60-90% of incidents are change-related.
// =============================================================================

/// Change event for correlation with incidents
/// Tracks deployments, commits, config changes that may cause incidents
model ChangeEvent {
  id          String   @id @default(uuid())
  tenantId    String?  // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  type        String // deployment, config, migration, commit, rollback
  source      String // render, github, manual, argocd, etc.
  timestamp   DateTime
  serviceId   String?
  description String?
  metadata    String? // JSON: { version, environment, author, url, etc. }
  riskScore   Int? // 0-100, calculated based on time proximity and change type

  createdAt DateTime @default(now())

  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([serviceId, timestamp])
  @@index([timestamp])
  @@index([type])
  @@map("change_events")
}

// =============================================================================
// SIMILAR INCIDENT TRACKING - FOR PATTERN MATCHING (BigPanda 30% Threshold)
// =============================================================================
// Track similarity between incidents for pattern detection and
// providing resolution hints based on past incidents.
// =============================================================================

/// Incident similarity record for pattern matching
/// Pre-calculated similarity scores for faster lookups
model IncidentSimilarity {
  id                String   @id @default(uuid())
  incidentId        String // Current incident
  similarIncidentId String // Similar past incident
  similarityScore   Int // 0-100 (BigPanda uses 30% threshold)
  matchFactors      String? // JSON: { titleMatch, serviceMatch, tagMatch, etc. }
  calculatedAt      DateTime @default(now())

  @@unique([incidentId, similarIncidentId])
  @@index([incidentId])
  @@index([similarIncidentId])
  @@index([similarityScore])
  @@map("incident_similarities")
}

// =============================================================================
// CORRELATION RULES - ALERT-TO-INCIDENT MATCHING
// =============================================================================

/// Correlation rule for grouping alerts into incidents
model CorrelationRule {
  id                String   @id @default(uuid())
  tenantId          String?  // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  name              String   @unique
  description       String?
  enabled           Boolean  @default(true)
  priority          Int      @default(100) // Lower = higher priority
  matchCriteria     String // JSON
  timeWindowMinutes Int      @default(60)
  action            String   @default("correlate") // correlate, suppress, create_incident
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  incidents Incident[]

  @@map("correlation_rules")
}

// =============================================================================
// SETTINGS - SYSTEM CONFIGURATION
// =============================================================================

/// System settings and configuration
model Setting {
  id          String   @id @default(uuid())
  tenantId    String?  // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  key         String   @unique
  value       String // JSON
  type        String   @default("string") // string, number, boolean, json, encrypted
  category    String? // general, correlation, ai, notifications, setup
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

// =============================================================================
// INTEGRATIONS
// =============================================================================
// Integration models (Integration, Connection, ServiceIntegration, etc.)
// are defined in integrations.prisma in the same schema directory.

// =============================================================================
// ALERT MAPPING RULES - MAP ALERTS TO SERVICES
// =============================================================================

/// Alert mapping rule for routing incoming alerts to services.
model AlertMappingRule {
  id          String  @id @default(uuid())
  tenantId    String? // dormant multi-tenancy hedge (ADR-0011 §6) — cloud-only, no reads/writes in OSS core
  name        String
  description String?
  priority    Int     @default(100) // Lower = higher priority
  enabled     Boolean @default(true)

  // Match conditions (JSON)
  matchCriteria String

  // Target service
  serviceId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([priority])
  @@index([enabled])
  @@index([serviceId])
  @@map("alert_mapping_rules")
}


// =============================================================================
// LICENSE MANAGEMENT
// =============================================================================
// SQLite version uses String for enums since SQLite doesn't support native enums.
// =============================================================================

/// License information for the installation.
model LicenseInfo {
  id String @id @default(uuid())

  // License identification
  licenseKey  String? @unique // The license key from Keygen.sh
  licenseType String  @default("none") // "none" | "subscription"
  tier        String  @default("community") // "community" | "enterprise"

  // Validity and activation
  validUntil    DateTime? // null for perpetual, set for subscription
  activatedAt   DateTime? // When the license was first activated
  lastValidated DateTime? // Last successful validation with license server

  // Entitlements (from Keygen policy)
  features String @default("[]") // JSON array: ["feat:extended_agents", "feat:sso", ...]
  quotas   String @default("{}") // JSON object: {"investigations_monthly": 500, ...}

  // Subscription-specific (for future use)
  billingCycle String? // "monthly", "annual" (null for perpetual)
  seats        Int? // null for unlimited, set for seat-based tiers

  // Cloud-hosted specific (for future cloud tiers)
  cloudInstanceId String? // Links to cloud deployment (pre-configured licenses)
  isCloudManaged  Boolean @default(false) // true = license managed by cloud, user never sees key

  // Customer metadata
  customerEmail String?
  customerName  String?
  metadata      String  @default("{}") // JSON for additional data from license server

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("license_info")
}
