{
  "openapi": "3.0.3",
  "info": {
    "title": "GitHub API - Curated Endpoints",
    "description": "Curated subset of GitHub API endpoints for code investigation",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.github.com"
    }
  ],
  "paths": {
    "/repos/{owner}/{repo}/contents/{path}": {
      "get": {
        "operationId": "repos_get_content",
        "summary": "Get repository content",
        "description": "Gets the contents of a file or directory in a repository",
        "tags": ["repos"],
        "parameters": [
          {
            "name": "owner",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Repository owner"
          },
          {
            "name": "repo",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Repository name"
          },
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "File path"
          },
          {
            "name": "ref",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Branch, tag, or commit SHA"
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/repos/{owner}/{repo}/commits": {
      "get": {
        "operationId": "repos_list_commits",
        "summary": "List commits",
        "description": "List commits on a repository",
        "tags": ["repos"],
        "parameters": [
          {
            "name": "owner",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "repo",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "sha",
            "in": "query",
            "schema": { "type": "string" },
            "description": "SHA or branch to start listing commits from"
          },
          {
            "name": "path",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter commits by file path"
          },
          {
            "name": "since",
            "in": "query",
            "schema": { "type": "string", "format": "date-time" },
            "description": "Only commits after this date"
          },
          {
            "name": "until",
            "in": "query",
            "schema": { "type": "string", "format": "date-time" },
            "description": "Only commits before this date"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "default": 30 },
            "description": "Results per page (max 100)"
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/repos/{owner}/{repo}/commits/{ref}": {
      "get": {
        "operationId": "repos_get_commit",
        "summary": "Get a commit",
        "description": "Get a specific commit by ref",
        "tags": ["repos"],
        "parameters": [
          {
            "name": "owner",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "repo",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "ref",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Commit SHA"
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/search/code": {
      "get": {
        "operationId": "search_code",
        "summary": "Search code",
        "description": "Search for code across repositories",
        "tags": ["search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Search query"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "default": 30 },
            "description": "Results per page (max 100)"
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/repos/{owner}/{repo}/pulls": {
      "get": {
        "operationId": "pulls_list",
        "summary": "List pull requests",
        "description": "List pull requests in a repository",
        "tags": ["pulls"],
        "parameters": [
          {
            "name": "owner",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "repo",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "state",
            "in": "query",
            "schema": { "type": "string", "enum": ["open", "closed", "all"], "default": "open" }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "default": 30 }
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/repos/{owner}/{repo}/pulls/{pull_number}": {
      "get": {
        "operationId": "pulls_get",
        "summary": "Get a pull request",
        "description": "Get a specific pull request",
        "tags": ["pulls"],
        "parameters": [
          {
            "name": "owner",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "repo",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/repos/{owner}/{repo}/actions/runs": {
      "get": {
        "operationId": "actions_list_workflow_runs",
        "summary": "List workflow runs",
        "description": "Lists all workflow runs for a repository",
        "tags": ["actions"],
        "parameters": [
          {
            "name": "owner",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "repo",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "status",
            "in": "query",
            "schema": { "type": "string", "enum": ["completed", "action_required", "cancelled", "failure", "neutral", "skipped", "stale", "success", "timed_out", "in_progress", "queued", "requested", "waiting", "pending"] }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "default": 30 }
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    }
  }
}
