{
  "name": "@prismalens/agents",
  "version": "0.1.0",
  "description": "PrismaLens multi-agent investigation executor with LangGraph",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "dev:studio": "npx @langchain/langgraph-cli@latest dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.4",
    "@langchain/core": "^1.1.27",
    "@langchain/google-genai": "^2.1.4",
    "@langchain/groq": "^1.0.3",
    "@langchain/langgraph": "^1.1.5",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/ollama": "^1.2.1",
    "@langchain/openai": "^1.2.1",
    "@prismalens/config": "workspace:*",
    "@prismalens/contracts": "workspace:*",
    "@prismalens/logger": "workspace:*",
    "deepagents": "^1.8.0",
    "langchain": "^1.2.25",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^0.0.1",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^3.2.0"
  }
}
