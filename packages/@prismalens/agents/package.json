{
	"name": "@prismalens/agents",
	"version": "0.1.0",
	"description": "PrismaLens Agent System - Hybrid DeepAgents + LangGraph for Incident Investigation",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
