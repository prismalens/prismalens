{
  "name": "@prismalens/agents",
  "version": "0.1.0",
  "description": "PrismaLens multi-agent investigation executor with LangGraph",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "studio": "npx @langchain/langgraph-cli@latest dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "eval:seed": "node --env-file=.env --import tsx ./src/evals/seed-datasets.ts",
    "eval:scenarios": "set -a && . ./.env && set +a && RUN_EVALS=true vitest run src/evals/scenarios.eval.test.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.21",
    "@langchain/community": "^1.1.20",
    "@langchain/core": "^1.1.29",
    "@langchain/google-genai": "^2.1.4",
    "@langchain/groq": "^1.0.3",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@langchain/ollama": "^1.2.1",
    "@langchain/openai": "^1.2.1",
    "@prismalens/config": "workspace:*",
    "@prismalens/contracts": "workspace:*",
    "cheerio": "^1.2.0",
    "deepagents": "^1.8.0",
    "langchain": "^1.2.28",
    "langsmith": "^0.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.1.14",
    "@types/node": "^22.10.5",
    "agentevals": "^0.0.6",
    "typescript": "^5.7.3",
    "vitest": "^3.2.0"
  }
}
