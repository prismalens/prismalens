{
	"name": "@prismalens/agents",
	"version": "0.1.0",
	"description": "PrismaLens Agent System - Hybrid DeepAgents + LangGraph for Incident Investigation",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./browser": {
			"import": "./dist/browser.js",
			"types": "./dist/browser.d.ts"
		},
		"./types": {
			"import": "./dist/types/index.js",
			"types": "./dist/types/index.d.ts"
		},
		"./llm": {
			"import": "./dist/llm/index.js",
			"types": "./dist/llm/index.d.ts"
		},
		"./tools": {
			"import": "./dist/tools/index.js",
			"types": "./dist/tools/index.d.ts"
		},
		"./agents": {
			"import": "./dist/agents/index.js",
			"types": "./dist/agents/index.d.ts"
		},
		"./graph": {
			"import": "./dist/graph/index.js",
			"types": "./dist/graph/index.d.ts"
		},
		"./executor": {
			"import": "./dist/executor/index.js",
			"types": "./dist/executor/index.d.ts"
		}
	},
	"scripts": {
		"dev": "tsc --watch",
		"build": "tsc",
		"lint": "eslint src/**/*.ts",
		"typecheck": "tsc --noEmit",
		"studio": "npx @langchain/langgraph-cli dev",
		"eval": "vitest run --config vitest.eval.config.ts",
		"eval:watch": "vitest --config vitest.eval.config.ts",
		"eval:e2e": "vitest run --config vitest.eval.config.ts evals/graph",
		"eval:agents": "vitest run --config vitest.eval.config.ts evals/components",
		"eval:tools": "vitest run --config vitest.eval.config.ts evals/tools",
		"eval:smoke": "vitest run --config vitest.eval.config.ts -t 'Smoke'",
		"docs:generate": "tsx scripts/generate-docs.ts"
	},
	"dependencies": {
		"@langchain/anthropic": "^1.3.4",
		"@langchain/core": "^1.1.15",
		"@langchain/google-genai": "^2.1.4",
		"@langchain/groq": "^1.0.3",
		"@langchain/langgraph": "^1.1.0",
		"@langchain/langgraph-checkpoint": "^1.0.0",
		"@langchain/langgraph-checkpoint-postgres": "^1.0.0",
		"@langchain/langgraph-checkpoint-sqlite": "^1.0.0",
		"@langchain/ollama": "^1.2.1",
		"@langchain/openai": "^1.2.1",
		"@modelcontextprotocol/sdk": "^1.0.0",
		"@prismalens/config": "workspace:*",
		"@prismalens/logger": "workspace:*",
		"date-fns": "^4.1.0",
		"langchain": "^1.2.16",
		"pg": "^8.13.1",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@faker-js/faker": "^9.3.0",
		"@langchain/langgraph-cli": "^1.1.11",
		"@types/node": "^22.10.5",
		"@types/pg": "^8.11.6",
		"@vitest/coverage-v8": "^3.2.4",
		"agentevals": "^0.0.6",
		"dotenv": "^17.2.3",
		"langsmith": "^0.3.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4",
		"zod-to-json-schema": "^3.24.5"
	},
	"peerDependencies": {
		"ioredis": "^5.4.2"
	},
	"peerDependenciesMeta": {
		"ioredis": {
			"optional": true
		}
	}
}
