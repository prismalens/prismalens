# =============================================================================
# LLM Provider (required for Studio and investigation execution)
# =============================================================================
PRISMALENS_LLM_PROVIDER=anthropic
PRISMALENS_LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Integrations (picked up by buildIntegrationsFromEnv for Studio + evals)
# =============================================================================
# RENDER_API_KEY=rnd_...
# RENDER_BASE_URL=https://api.render.com
# GITHUB_TOKEN=ghp_...
# GITHUB_BASE_URL=https://api.github.com
# PROMETHEUS_USERNAME=admin
# PROMETHEUS_PASSWORD=...
# PROMETHEUS_BASE_URL=http://localhost:9090

# =============================================================================
# LangSmith (required for evals, optional for dev tracing)
# =============================================================================
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGCHAIN_PROJECT=prismalens-agents-dev

# =============================================================================
# Scenario Evals (real LLM, mock HTTP — no running API needed)
# =============================================================================
# RUN_EVALS=true                           # gate for all evals
# EVAL_LLM_JUDGE=true                      # gate for expensive LLM judge evals
# GIT_SHA=abc123                           # tags experiments for comparison
#
# PRISMALENS_LLM_PROVIDER and PRISMALENS_LLM_MODEL are REQUIRED for evals (no defaults).
# Set them above in the LLM Provider section.
