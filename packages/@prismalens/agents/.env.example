# =============================================================================
# PrismaLens Agents - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# =============================================================================

# =============================================================================
# 1. LANGSMITH (Required for tracing & evals)
# =============================================================================
# Get your API key from: https://smith.langchain.com → Settings → API Keys

LANGSMITH_API_KEY=lsv2_pt_xxx
LANGSMITH_PROJECT=prismalens-agents-dev
LANGSMITH_TRACING=true
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# =============================================================================
# 2. LLM PROVIDER API KEYS
# =============================================================================
# Set API keys for providers you want to use. You only need keys for providers
# you'll actually use (base or per-agent overrides).

# Groq (recommended - FREE tier)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxx

# OpenRouter (FREE tier available)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxx

# Ollama (local = FREE, cloud = requires key)
# Local: Just run `ollama serve` - no key needed
# Cloud: Get key from https://ollama.com/settings/keys for kimi-k2.5:cloud
OLLAMA_API_KEY=ollama_xxx
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic (paid)
# Get key: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (paid)
# Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxx

# Google (paid)
# Get key: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=xxx


# =============================================================================
# 3. LLM CONFIGURATION
# =============================================================================
# How the multi-provider system works:
#
#   1. BASE CONFIG: All agents use this by default
#   2. PER-AGENT OVERRIDES: Override specific agents to use different providers
#
# Example: Base = local Ollama, but Commander uses fast Groq
#
#   PRISMALENS_LLM_PROVIDER=ollama          ← Base provider
#   PRISMALENS_LLM_MODEL=qwen3:14b          ← Base model
#   PRISMALENS_COMMANDER_PROVIDER=groq      ← Override Commander
#   PRISMALENS_COMMANDER_MODEL=llama-3.3-70b-versatile
#
# -----------------------------------------------------------------------------

# Base LLM Configuration (used by all agents unless overridden)
PRISMALENS_LLM_PROVIDER=groq
PRISMALENS_LLM_MODEL=llama-3.3-70b-versatile

# For Ollama, also set:
# PRISMALENS_OLLAMA_BASE_URL=http://localhost:11434


# =============================================================================
# 4. PER-AGENT OVERRIDES (Optional)
# =============================================================================
# Override the base config for specific agents. Useful for:
#   - Cost optimization: Use free Groq for fast agents, paid for reasoning
#   - Capability matching: Code model for Surgeon, reasoning model for Detective
#
# Agents: COMMANDER, GATHERER, DETECTIVE, SURGEON, ADVERSARY
# Format: PRISMALENS_{AGENT}_PROVIDER and PRISMALENS_{AGENT}_MODEL
#
# -----------------------------------------------------------------------------
# Agent Roles:
#   COMMANDER    - Orchestrates investigation, delegates to other agents
#   GATHERER - Gathers context (code, logs, changes)
#   DETECTIVE    - Analyzes evidence, forms hypotheses with confidence scores
#   SURGEON      - Proposes fixes and remediation steps
#   ADVERSARY    - Challenges hypotheses (devil's advocate)
# -----------------------------------------------------------------------------

# PRISMALENS_COMMANDER_PROVIDER=groq
# PRISMALENS_COMMANDER_MODEL=llama-3.3-70b-versatile

# PRISMALENS_GATHERER_PROVIDER=groq
# PRISMALENS_GATHERER_MODEL=llama-3.3-70b-versatile

# PRISMALENS_DETECTIVE_PROVIDER=ollama
# PRISMALENS_DETECTIVE_MODEL=kimi-k2.5:cloud

# PRISMALENS_SURGEON_PROVIDER=ollama
# PRISMALENS_SURGEON_MODEL=qwen3-coder:30b

# PRISMALENS_ADVERSARY_PROVIDER=groq
# PRISMALENS_ADVERSARY_MODEL=llama-3.3-70b-versatile


# =============================================================================
# 5. TEST CONFIGURATION
# =============================================================================
# Settings specific to running evaluations (pnpm eval).
# LLM configuration is shared with production (PRISMALENS_LLM_* above).

# Test timeout (default: 300000 = 5 min)
# Increase for slower LLMs or complex tests
# TEST_TIMEOUT_MS=600000

# Integration mocks for GitHub-based evals
TEST_GITHUB_TOKEN=ghp_xxx
TEST_GITHUB_OWNER=prismalens-org
TEST_GITHUB_REPO=prismalens

# -----------------------------------------------------------------------------
# LLM-as-Judge Configuration
# -----------------------------------------------------------------------------
# The LLM judge evaluates agent outputs semantically (costs tokens).
# Use a different model than your main agent to avoid self-judging bias.

# Enable LLM-as-Judge evaluation (default: false)
# Set to "true" for CI runs, leave false for fast local development
# TEST_USE_LLM_JUDGE=true

# Judge model provider (optional, falls back to PRISMALENS_LLM_PROVIDER)
# Using a different provider for judging helps avoid bias
# TEST_JUDGE_PROVIDER=openai

# Judge model name (optional, falls back to PRISMALENS_LLM_MODEL)
# gpt-4o-mini is cost-effective for evaluation tasks
# TEST_JUDGE_MODEL=gpt-4o-mini

# Example configurations:
#
# 1. Use OpenAI for judging while Groq runs agents:
#    PRISMALENS_LLM_PROVIDER=groq
#    PRISMALENS_LLM_MODEL=llama-3.3-70b-versatile
#    TEST_JUDGE_PROVIDER=openai
#    TEST_JUDGE_MODEL=gpt-4o-mini
#
# 2. Use Claude for judging while Ollama runs agents:
#    PRISMALENS_LLM_PROVIDER=ollama
#    PRISMALENS_LLM_MODEL=qwen3:14b
#    TEST_JUDGE_PROVIDER=anthropic
#    TEST_JUDGE_MODEL=claude-3-5-haiku-20241022