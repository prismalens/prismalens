# =============================================================================
# PrismaLens Agents - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# LangSmith (required for tracing & evals)
# Get your API key from: https://smith.langchain.com → Settings → API Keys
# -----------------------------------------------------------------------------
LANGSMITH_API_KEY=lsv2_pt_xxx
LANGSMITH_PROJECT=prismalens-agents-dev
LANGSMITH_TRACING=true
LANGCHAIN_TRACING_V2=true

# -----------------------------------------------------------------------------
# LLM Provider
# Options: groq, openai, anthropic, google, ollama, openrouter
# Groq is recommended for development (free tier: 100k tokens/day)
# -----------------------------------------------------------------------------
PRISMALENS_LLM_PROVIDER=groq

# Groq (recommended - free tier)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxx

# OpenAI (alternative)
# OPENAI_API_KEY=sk-xxx

# Anthropic (alternative)
# ANTHROPIC_API_KEY=sk-ant-xxx

# -----------------------------------------------------------------------------
# Test Database Seeding (for evals only)
# These are used to seed test.db with integration connections.
# They are NOT used by the app directly - only by the seed script.
# -----------------------------------------------------------------------------

# GitHub integration
# Get a personal access token from: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public only)
TEST_GITHUB_TOKEN=ghp_xxx
TEST_GITHUB_OWNER=prismalens-org
TEST_GITHUB_REPO=prismalens

# Render integration (optional)
# Get your API key from: https://dashboard.render.com/u/settings/api-keys
# TEST_RENDER_API_KEY=rnd_xxx
# TEST_RENDER_SERVICE_ID=srv-xxx
