{
	"name": "@prismalens/config",
	"version": "0.1.0",
	"description": "Shared configuration and environment variable management for PrismaLens",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./llm": {
			"types": "./dist/llm.d.ts",
			"import": "./dist/llm.js"
		},
		"./harness": {
			"types": "./dist/harness.d.ts",
			"import": "./dist/harness.js"
		},
		"./mcp": {
			"types": "./dist/mcp.d.ts",
			"import": "./dist/mcp.js"
		},
		"./agents": {
			"types": "./dist/agents.d.ts",
			"import": "./dist/agents.js"
		},
		"./integrations": {
			"types": "./dist/integrations.d.ts",
			"import": "./dist/integrations.js"
		},
		"./investigation": {
			"types": "./dist/investigation.d.ts",
			"import": "./dist/investigation.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"clean": "rm -rf dist && rm -rf node_modules",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"typescript": "^5.7.0"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"files": [
		"dist",
		"src"
	]
}
