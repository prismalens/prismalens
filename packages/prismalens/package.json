{
	"name": "prismalens",
	"version": "0.1.0",
	"description": "AI-powered incident investigation platform - CLI tool to run PrismaLens locally",
	"author": "PrismaLens Team",
	"license": "ELv2",
	"homepage": "https://github.com/prismalens-org/prismalens",
	"repository": {
		"type": "git",
		"url": "https://github.com/prismalens-org/prismalens.git",
		"directory": "packages/prismalens"
	},
	"bugs": {
		"url": "https://github.com/prismalens-org/prismalens/issues"
	},
	"keywords": [
		"incident",
		"investigation",
		"ai",
		"llm",
		"observability",
		"root-cause-analysis",
		"monitoring",
		"alerting"
	],
	"bin": {
		"prismalens": "./bin/prismalens"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"engines": {
		"node": ">=20.0.0"
	},
	"files": [
		"bin",
		"dist",
		"bundled",
		"templates",
		"prisma"
	],
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "pnpm build:ts && pnpm build:bundle",
		"build:ts": "tsup",
		"build:bundle": "node scripts/bundle.mjs",
		"clean": "rm -rf dist bundled && rm -rf node_modules",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src/",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@prismalens/config": "workspace:*",
		"chalk": "^5.3.0",
		"commander": "^13.0.0",
		"dotenv": "^16.4.7",
		"ora": "^8.1.1",
		"semver": "^7.6.0",
		"source-map-support": "^0.5.21"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"@types/semver": "^7.5.8",
		"@types/source-map-support": "^0.5.10",
		"tsup": "^8.3.5",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	},
	"publishConfig": {
		"access": "public"
	}
}
