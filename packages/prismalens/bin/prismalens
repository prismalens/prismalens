#!/usr/bin/env node

/**
 * PrismaLens CLI Entry Point
 *
 * This is the main entry point for the PrismaLens CLI.
 * It handles version checks, Node.js validation, and bootstraps the CLI.
 */

import { createRequire } from 'module';
import { fileURLToPath } from 'url';
import { dirname, resolve } from 'path';

const require = createRequire(import.meta.url);
const __dirname = dirname(fileURLToPath(import.meta.url));

// Early version flag handling
const lastArg = process.argv.slice(-1)[0];
if (['-v', '-V', '--version'].includes(lastArg) && process.argv.length === 3) {
  const pkg = require('../package.json');
  console.log(pkg.version);
  process.exit(0);
}

// Node.js version validation
const pkg = require('../package.json');
const requiredVersion = pkg.engines?.node;

if (requiredVersion) {
  const semver = await import('semver');
  if (!semver.default.satisfies(process.versions.node, requiredVersion)) {
    console.error(
      `\n  Error: PrismaLens requires Node.js ${requiredVersion}\n` +
        `  Current version: ${process.versions.node}\n` +
        `  Please upgrade Node.js and try again.\n`,
    );
    process.exit(1);
  }
}

// Source map support for better error traces
try {
  const sourceMapSupport = await import('source-map-support');
  sourceMapSupport.default.install();
} catch {
  // Source map support is optional
}

// Load environment variables
const dotenv = await import('dotenv');
dotenv.config();

// Bootstrap CLI
try {
  const { CommandRegistry } = await import('../dist/command-registry.js');
  const registry = new CommandRegistry();
  await registry.execute();
} catch (error) {
  if (error instanceof Error) {
    console.error(`\n  Error: ${error.message}\n`);
    if (process.env.DEBUG) {
      console.error(error.stack);
    }
  }
  process.exit(1);
}
