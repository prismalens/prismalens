{
  "name": "@prismalens/worker-python",
  "version": "0.1.0",
  "private": true,
  "description": "PrismaLens Python Worker - Google ADK Agent Execution",
  "scripts": {
    "dev": "uv run python worker.py --mode regular",
    "start": "uv run python worker.py",
    "start:regular": "uv run python worker.py --mode regular",
    "start:queue": "uv run python worker.py --mode queue",
    "test": "uv run pytest",
    "test:unit": "uv run pytest tests/test_executor.py -v",
    "test:integration": "uv run pytest tests/test_queue_integration.py -v",
    "lint": "uv run ruff check .",
    "lint:fix": "uv run ruff check . --fix",
    "typecheck": "uv run mypy .",
    "install": "uv sync",
    "install:dev": "uv sync --extra dev"
  },
  "keywords": [
    "prismalens",
    "worker",
    "python",
    "adk",
    "agents"
  ]
}
