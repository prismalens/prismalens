{
	"name": "@prismalens/worker",
	"version": "0.1.0",
	"description": "PrismaLens Worker - BullMQ Queue Worker for Agent Execution",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
