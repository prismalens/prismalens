{
	"name": "prismalens",
	"version": "0.0.2",
	"description": "AI root-cause investigation from your terminal — point it at a repo, pipe it an alert, get an evidence-linked report",
	"license": "Apache-2.0",
	"type": "module",
	"bin": {
		"prismalens": "./dist/bin/prismalens.js",
		"pl": "./dist/bin/prismalens.js"
	},
	"files": [
		"dist",
		"NOTICE"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prismalens/prismalens.git",
		"directory": "packages/cli"
	},
	"homepage": "https://prismalens.io",
	"bugs": "https://github.com/prismalens/prismalens/issues",
	"keywords": [
		"sre",
		"incident-response",
		"root-cause-analysis",
		"investigation",
		"observability",
		"devops",
		"ai",
		"cli"
	],
	"engines": {
		"node": ">=22"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"dev": "tsx bin/prismalens.ts",
		"test": "vitest run --coverage"
	},
	"dependencies": {
		"@prismalens/config": "workspace:*",
		"@prismalens/contracts": "workspace:*",
		"@prismalens/engine": "workspace:*",
		"citty": "^0.2.2",
		"consola": "^3.4.2",
		"env-paths": "^4.0.0",
		"json-rpc-2.0": "^1.7.1",
		"yaml": "^2.9.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "^4.1.9",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
