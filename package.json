{
	"name": "prismalens-monorepo",
	"version": "0.1.0",
	"private": true,
	"description": "Open-source AI-powered incident analysis and root cause detection",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/prismalens/prismalens.git"
	},
	"scripts": {
		"postinstall": "pnpm rebuild better-sqlite3",
		"build": "turbo run build",
		"dev": "turbo run dev",
		"dev:api": "turbo run dev --filter=@prismalens/api",
		"dev:frontend": "turbo run dev --filter=@prismalens/frontend",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck",
		"clean": "turbo run clean && rm -rf node_modules",
		"db:init": "turbo run db:init --filter=@prismalens/database",
		"db:migrate": "turbo run db:migrate --filter=@prismalens/database",
		"db:generate": "turbo run db:generate --filter=@prismalens/database",
		"db:studio": "turbo run db:studio --filter=@prismalens/database",
		"db:reset": "turbo run db:reset --filter=@prismalens/database",
		"format-and-lint": "biome check .",
		"format-and-lint:fix": "biome check . --write",
		"spdx:check": "node scripts/spdx-headers.mjs --check",
		"spdx:fix": "node scripts/spdx-headers.mjs --fix",
		"publint": "pnpm --filter prismalens --filter @prismalens/engine --filter @prismalens/contracts --filter @prismalens/config exec publint --strict",
		"changeset:version": "changeset version",
		"changeset:publish": "pnpm publish -r --no-git-checks && changeset tag"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@changesets/cli": "^2.31.0",
		"@types/node": "catalog:",
		"publint": "^0.3.21",
		"tsx": "catalog:",
		"turbo": "^2.10.2",
		"typescript": "catalog:"
	},
	"packageManager": "pnpm@10.27.0",
	"engines": {
		"node": ">=22.13.0",
		"pnpm": ">=9.0.0"
	},
	"pnpm": {
		"overrides": {
			"vite": "^8.1.3",
			"ws": ">=8.21.0",
			"multer": ">=2.2.0",
			"solid-js": ">=1.9.4",
			"@hono/node-server": ">=1.19.13",
			"ioredis": "^5.11.1"
		}
	}
}
