# Copy to `.env` (gitignored) and fill in. NEVER commit a real key.
# Free Gemini key: https://aistudio.google.com

# --- Gemini backend (default) ---
GOOGLE_API_KEY=
# Pick a CURRENT model from https://aistudio.google.com/ — names change over time.
GEMINI_MODEL=gemini-2.5-flash

# --- Ollama backend (local, no key) — used with `--backend ollama` ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# --- OpenAI-compatible backend — used with `--backend openai` ---
# Defaults to Gemini's OpenAI-compat endpoint reusing GOOGLE_API_KEY above (proves the
# swappable seam at $0). Uncomment to target real OpenAI / Groq / OpenRouter instead.
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Shell tool ---
# Path to the read-only allowlist (deny-by-default). Defaults to allowlist.example.json.
SPIKE_ALLOWLIST_FILE=allowlist.example.json
