# Dev Seed: Integration Credentials
# Copy to .env.seed and fill in your values.
# This file is gitignored — never commit .env.seed with real credentials.

# GitHub App Integration (required for VCS features)
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=./path/to/your-app.private-key.pem
GITHUB_APP_INSTALLATION_ID=12345678
GITHUB_APP_ORG=                        # optional: GitHub organization name
GITHUB_APP_WEBHOOK_SECRET=             # optional: GitHub App webhook secret

# Render Integration (optional, for deployment features)
RENDER_API_KEY=rnd_xxxxx
